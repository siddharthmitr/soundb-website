{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "text"
    },
    "body": {
      "type": "blocks"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "industry",
        "technology",
        "events",
        "breaking",
        "analysis",
        "opinion",
        "coverStory"
      ]
    },
    "author": {
      "type": "string"
    },
    "date": {
      "type": "date"
    },
    "readTime": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "color": {
      "type": "string"
    },
    "tags": {
      "type": "json"
    },
    "coverStory": {
      "type": "boolean",
      "default": false
    }
  }
}
